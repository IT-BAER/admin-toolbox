<Window x:Class="AdminToolbox.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        xmlns:local="clr-namespace:AdminToolbox.Views"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Admin Toolbox"
        MinWidth="520" MinHeight="420"
        Width="620" Height="580"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource SystemControlBackgroundAltHighBrush}"
        StateChanged="Window_StateChanged"
        Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== Title bar area ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <ui:FontIcon Glyph="&#xE8D7;" FontSize="22"
                                 Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                 Margin="0,0,10,0"/>
                    <StackPanel>
                        <TextBlock Text="Admin Toolbox" FontSize="16" FontWeight="SemiBold"/>
                        <TextBlock x:Name="UserLabel"
                                   FontSize="11" Opacity="0.6"/>
                    </StackPanel>
                </StackPanel>

                <!-- Refresh / Lock buttons -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button x:Name="RefreshButton"
                            Click="RefreshButton_Click"
                            ToolTip="Refresh detected RSAT tools"
                            Style="{DynamicResource DefaultButtonStyle}"
                            Padding="8,6" Margin="0,0,4,0">
                        <ui:FontIcon Glyph="&#xE72C;" FontSize="14"/>
                    </Button>
                    <Button x:Name="LockButton"
                            Click="LockButton_Click"
                            ToolTip="Lock — clear credentials from memory"
                            Style="{DynamicResource DefaultButtonStyle}"
                            Padding="8,6" Margin="0,0,4,0">
                        <ui:FontIcon Glyph="&#xE72E;" FontSize="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Tool grid ===== -->
        <ScrollViewer x:Name="ToolsScrollViewer" Grid.Row="1"
                      VerticalScrollBarVisibility="Auto" Padding="16"
                      CanContentScroll="False"
                      PreviewMouseWheel="ToolsScrollViewer_PreviewMouseWheel">
            <ItemsControl x:Name="ToolsItemsControl" HorizontalAlignment="Center">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Width="160" Height="140"
                                Margin="8"
                                Click="ToolButton_Click"
                                Tag="{Binding}"
                                ToolTip="{Binding Description}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="CardBorder"
                                            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                                            CornerRadius="8"
                                            BorderThickness="1"
                                            BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}">

                                        <StackPanel x:Name="CardContent"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Margin="12">
                                            <ui:FontIcon Glyph="{Binding IconGlyph}"
                                                         FontSize="36"
                                                         Foreground="{DynamicResource SystemControlForegroundAccentBrush}"
                                                         HorizontalAlignment="Center"/>
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,10,0,4"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"/>
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="10" Opacity="0.6"
                                                       HorizontalAlignment="Center"
                                                       TextWrapping="Wrap"
                                                       TextAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="CardBorder"
                                                    Property="Background"
                                                    Value="{DynamicResource SystemControlHighlightListLowBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="CardBorder"
                                                    Property="Background"
                                                    Value="{DynamicResource SystemControlHighlightListMediumBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- ===== Status bar ===== -->
        <Border Grid.Row="2"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                Padding="16,6">
            <TextBlock x:Name="StatusBar"
                       FontSize="11" Opacity="0.7"
                       Text="Ready — click a tool to launch it with your domain admin credentials."/>
        </Border>
    </Grid>
</Window>
